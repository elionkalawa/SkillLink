# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-secret" # Use `openssl rand -base64 32` to generate

# Google OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Supabase Datbase (For Auth & App Data)
# Make sure to use the connection pooler URL or standard connection URL
NEXT_PUBLIC_SUPABASE_URL="https://your-project-url.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Connection String for any potential ORM like Drizzle/Prisma (Optional)
DATABASE_URL="postgres://postgres.abc:yourpassword@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"